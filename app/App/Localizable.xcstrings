    "Check for Updates…": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Procurar atualizações…"
          }
        }
      }
    },
    "Updates are signed and verified before installing.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As atualizações são assinadas e verificadas antes de instalar."
          }
        }
      }
    },
    "Last checked %@": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Última verificação %@"
          }
        }
      }
    },
    "Start-up control for MacBooks": {
      "extractionState": "manual",
      "localizations": {

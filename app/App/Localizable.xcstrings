{
  "sourceLanguage": "en",
  "version": "1.0",
  "strings": {
    "LidBoot": {
      "extractionState": "manual",
      "shouldTranslate": false
    },
    "Opening the lid": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao abrir a tampa"
          }
        }
      }
    },
    "Connecting power": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao ligar à corrente"
          }
        }
      }
    },
    "Plugging in starts your Mac": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligar a ficha arranca o Mac"
          }
        }
      }
    },
    "Plugging in just charges it": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligar a ficha apenas carrega a bateria"
          }
        }
      }
    },
    "Start up when opening the lid": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrancar ao abrir a tampa"
          }
        }
      }
    },
    "Start up when connecting power": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrancar ao ligar à corrente"
          }
        }
      }
    },
    "Changing this asks for your password": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterar isto pede a tua palavra-passe"
          }
        }
      }
    },
    "On. %@": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligado. %@"
          }
        }
      }
    },
    "Off. %@": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desligado. %@"
          }
        }
      }
    },
    "Start-up is limited": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Arranque automático limitado"
          }
        }
      }
    },
    "Default start-up behaviour": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Comportamento de arranque predefinido"
          }
        }
      }
    },
    "Your Mac still starts up if you press a key or touch the trackpad.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O teu Mac continua a arrancar se carregares numa tecla ou tocares no trackpad."
          }
        }
      }
    },
    "Starts up when you open the lid or connect power.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Arranca ao abrir a tampa ou ao ligar à corrente."
          }
        }
      }
    },
    "Won't start up when you open the lid.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não arranca ao abrir a tampa."
          }
        }
      }
    },
    "Won't start up when you connect power.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não arranca ao ligar à corrente."
          }
        }
      }
    },
    "Show LidBoot in": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostrar o LidBoot em"
          }
        }
      }
    },
    "Menu Bar": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Barra de menus"
          }
        }
      }
    },
    "Dock": {
      "extractionState": "manual",
      "shouldTranslate": false
    },
    "Both": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ambos"
          }
        }
      }
    },
    "Hide the Dock icon?": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ocultar o ícone da Dock?"
          }
        }
      }
    },
    "Cancel": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancelar"
          }
        }
      }
    },
    "Use Menu Bar Only": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Usar apenas a barra de menus"
          }
        }
      }
    },
    "LidBoot will only be reachable from its menu bar icon. If your menu bar is full, macOS may not have room to show it — this is common on Macs with a notch.\n\nIf you can't find the icon, open LidBoot again from Finder or Launchpad and this window will come back.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O LidBoot só ficará acessível pelo ícone na barra de menus. Se a tua barra de menus estiver cheia, o macOS pode não ter espaço para o mostrar — o que é comum em Macs com notch.\n\nSe não encontrares o ícone, abre o LidBoot outra vez a partir do Finder ou do Launchpad e esta janela reaparece."
          }
        }
      }
    },
    "Open at login": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir ao iniciar sessão"
          }
        }
      }
    },
    "Just for quick access — your setting holds either way": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas para acesso rápido — a definição mantém-se"
          }
        }
      }
    },
    "Needs approval in System Settings › Login Items. Click to open.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Precisa de aprovação em Definições do Sistema › Itens de Início de Sessão. Clica para abrir."
          }
        }
      }
    },
    "Couldn't change this setting.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível alterar esta definição."
          }
        }
      }
    },
    "Version %@": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Versão %@"
          }
        }
      }
    },
    "Settings…": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Definições…"
          }
        }
      }
    },
    "Quit": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Sair"
          }
        }
      }
    },
    "macOS couldn't verify your password, so nothing changed.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O macOS não conseguiu verificar a tua palavra-passe, por isso nada mudou."
          }
        }
      }
    },
    "Couldn't prepare the system command.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível preparar o comando do sistema."
          }
        }
      }
    },
    "The system refused the change (%lld).": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O sistema recusou a alteração (%lld)."
          }
        }
      }
    },
    "This setting needs macOS 15 (Sequoia) or later. You're on %@.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta definição precisa do macOS 15 (Sequoia) ou posterior. Estás no %@."
          }
        }
      }
    },
    "Restore Default": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Repor predefinição"
          }
        }
      }
    },
    "Removes the setting, returning your Mac to how it shipped": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove a definição, devolvendo o teu Mac ao estado de origem"
          }
        }
      }
    },
    "Copied": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiado"
          }
        }
      }
    },
    "Opening the lid starts your Mac": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir a tampa arranca o Mac"
          }
        }
      }
    },
    "Opening the lid won't start your Mac": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir a tampa não arranca o Mac"
          }
        }
      }
    },
    "Won't start up from the lid or from power.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não arranca pela tampa nem pela corrente."
          }
        }
      }
    },
    "Unknown": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desconhecido"
          }
        }
      }
    },
    "Applies when your Mac is shut down. Waking it from sleep isn't affected.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica-se quando o Mac está desligado. Acordá-lo do modo de repouso não é afetado."
          }
        }
      }
    },
    "Changing either switch asks for your Mac password.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterar qualquer um dos interruptores pede a palavra-passe do Mac."
          }
        }
      }
    },
    "LidBoot needs your password to change your Mac's start-up setting.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O LidBoot precisa da tua palavra-passe para alterar a definição de arranque do Mac."
          }
        }
      }
    },
    "BootPreference is set to a value LidBoot doesn't recognise (0x%@), so it won't change it.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O BootPreference está definido para um valor que o LidBoot não reconhece (0x%@), por isso não o vai alterar."
          }
        }
      }
    },
    "BootPreference holds a value LidBoot can't read, so it won't change it.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O BootPreference tem um valor que o LidBoot não consegue ler, por isso não o vai alterar."
          }
        }
      }
    },
    "This setting only exists on Apple silicon Macs. Your Mac uses different firmware that LidBoot doesn't support.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta definição só existe em Macs com Apple silicon. O teu Mac usa firmware diferente que o LidBoot não suporta."
          }
        }
      }
    },
    "This setting only applies to Mac laptops with a lid.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta definição só se aplica a portáteis Mac com tampa."
          }
        }
      }
    },
    "LidBoot can't help this Mac": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O LidBoot não pode ajudar este Mac"
          }
        }
      }
    },
    "Apple's documentation": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Documentação da Apple"
          }
        }
      }
    },
    "macOS wouldn't show the authorization prompt, so nothing changed.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O macOS não mostrou o pedido de autorização, por isso nada mudou."
          }
        }
      }
    },
    "macOS accepted the change, but the setting reads back differently. The switches show what your Mac actually reports.": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O macOS aceitou a alteração, mas a definição é lida de forma diferente. Os interruptores mostram o que o teu Mac realmente reporta."
          }
        }
      }
    },
    "Open LidBoot…": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Abrir o LidBoot…"
          }
        }
      }
    },
    "Quit LidBoot": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Sair do LidBoot"
          }
        }
      }
    },

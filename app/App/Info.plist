<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<!--
	  Two names on purpose, same split as Grid Push: the product/file/bundle-id
	  stay "LidBoot" (no spaces — scripts, URLs and the DMG name depend on that),
	  while everything a person reads says "Lid Boot".
	-->
	<key>CFBundleName</key>
	<string>Lid Boot</string>
	<key>CFBundleDisplayName</key>
	<string>Lid Boot</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.utilities</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<!--
	  Starts as an accessory (no Dock icon), then AppDelegate promotes to a
	  regular app at launch when the user's mode includes the Dock. Doing it in
	  this direction means menu-bar-only users never see a Dock icon flash.

	  Load-bearing: applicationWillFinishLaunching's applyActivationPolicy() call
	  is the ONLY thing that puts the Dock icon back. Don't remove it.
	-->
	<key>LSUIElement</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 Hexadexa. All rights reserved.</string>

	<!--
	  Sparkle auto-update, same model as Observio.

	  The feed is a branded URL rather than the raw GitHub one on purpose: it's a
	  Cloudflare redirect, so where the appcast actually lives can change without
	  shipping a new build. This URL is baked into every release — getting it
	  wrong means silently broken updates for everyone already on that build.

	  Integrity is the EdDSA signature below, NOT the transport or repo privacy,
	  which is why the appcast and DMGs can sit in a public repo while the source
	  stays private.
	-->
	<key>SUFeedURL</key>
	<string>https://lidboot.hexadexa.io/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>g1lZN7FLgwSgc3RkOf68sK7MLhSpjwL45aM7NSLs1Ps=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>

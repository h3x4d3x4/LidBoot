<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<!-- One name everywhere — "LidBoot", joined. The spaced "Lid Boot" split
	     was tried and deliberately reverted; don't reintroduce it. -->
	<key>CFBundleName</key>
	<string>LidBoot</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.utilities</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<!--
	  Starts as an accessory (no Dock icon), then AppDelegate promotes to a
	  regular app at launch when the user's mode includes the Dock. Doing it in
	  this direction means menu-bar-only users never see a Dock icon flash.

	  Load-bearing: applicationWillFinishLaunching's applyActivationPolicy() call
	  is the ONLY thing that puts the Dock icon back. Don't remove it.
	-->
	<key>LSUIElement</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 Hexadexa. All rights reserved.</string>

	<!--
	  Sparkle feed. Since the source is open, the appcast and release DMGs live in
	  this repo — the separate releases repo only existed so a private-source app
	  could serve a token-free feed.

	  This URL is baked into every build: the repo name is effectively permanent,
	  and build-dmg.sh HARD-FAILS if a build carries any other feed URL (a stale
	  or reverted plist already shipped one wrong build).

	  Integrity is the EdDSA signature below, not the transport.
	-->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/h3x4d3x4/LidBoot/main/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>g1lZN7FLgwSgc3RkOf68sK7MLhSpjwL45aM7NSLs1Ps=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
